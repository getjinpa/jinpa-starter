---
/**
 * SocialShareEnhanced — Jinpa Plugin Component
 *
 * A polished social-sharing bar supporting: Twitter/X, Facebook, LinkedIn,
 * WhatsApp, Telegram, Reddit, Email, and Copy Link. Includes a floating
 * share button for mobile viewports.
 *
 * All CSS classes are prefixed with "social-share-enhanced-" per Jinpa
 * plugin conflict resolution rules. Default hydration: client:visible.
 */

interface Props {
  /** The canonical URL of the page being shared. */
  url: string;
  /** The page / post title. */
  title: string;
  /** Optional description used by some share targets. */
  description?: string;
  /**
   * Which platforms to display. Order is preserved.
   * Supported: twitter, facebook, linkedin, whatsapp, telegram, reddit, email, copy
   */
  platforms?: string[];
  /** "inline" (default) renders a horizontal bar; "vertical" stacks icons. */
  layout?: 'inline' | 'vertical';
  /** Show text labels next to icons. */
  showLabels?: boolean;
  /** Show the floating mobile share button (bottom-right). */
  showFloatingButton?: boolean;
}

const {
  url,
  title,
  description = '',
  platforms = ['twitter', 'facebook', 'linkedin', 'whatsapp', 'telegram', 'reddit', 'email', 'copy'],
  layout = 'inline',
  showLabels = false,
  showFloatingButton = true,
} = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedDesc = encodeURIComponent(description);

/* ----- Share link definitions ------------------------------------------ */

const shareLinks: Record<string, { href: string; label: string; ariaLabel: string }> = {
  twitter: {
    href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
    label: 'Twitter',
    ariaLabel: 'Share on Twitter',
  },
  facebook: {
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
    label: 'Facebook',
    ariaLabel: 'Share on Facebook',
  },
  linkedin: {
    href: `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}&title=${encodedTitle}`,
    label: 'LinkedIn',
    ariaLabel: 'Share on LinkedIn',
  },
  whatsapp: {
    href: `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`,
    label: 'WhatsApp',
    ariaLabel: 'Share on WhatsApp',
  },
  telegram: {
    href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
    label: 'Telegram',
    ariaLabel: 'Share on Telegram',
  },
  reddit: {
    href: `https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`,
    label: 'Reddit',
    ariaLabel: 'Share on Reddit',
  },
  email: {
    href: `mailto:?subject=${encodedTitle}&body=${encodedDesc ? encodedDesc + '%0A%0A' : ''}${encodedUrl}`,
    label: 'Email',
    ariaLabel: 'Share via email',
  },
  copy: {
    href: '#',
    label: 'Copy Link',
    ariaLabel: 'Copy link to clipboard',
  },
};

/* ----- SVG icons per platform ------------------------------------------ */

const icons: Record<string, string> = {
  twitter: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>`,
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>`,
  telegram: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 4.4L2.4 10.6c-.6.2-.6 1.1 0 1.3l4.8 1.6 1.6 4.8c.2.6 1.1.6 1.3 0l2.4-4.8 4.8 2.4c.4.2.9-.1.8-.6L21.2 4.4z"/><line x1="10.8" y1="13.2" x2="21.2" y2="4.4"/></svg>`,
  reddit: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="14" r="7"/><circle cx="9" cy="13" r="1" fill="currentColor"/><circle cx="15" cy="13" r="1" fill="currentColor"/><path d="M9 16c.6.8 1.7 1.3 3 1.3s2.4-.5 3-1.3"/><path d="M19.5 7.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M17.5 8l1.5-1"/><line x1="12" y1="7" x2="12" y2="3"/><line x1="12" y1="3" x2="16" y2="3"/></svg>`,
  email: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  copy: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`,
};

const activePlatforms = platforms.filter((p) => shareLinks[p]);
---

<!-- ===================================================================== -->
<!--  Inline / Vertical Share Bar                                          -->
<!-- ===================================================================== -->
<div
  class={`social-share-enhanced-bar social-share-enhanced-${layout}`}
  data-social-share-enhanced
>
  <span class="social-share-enhanced-label">Share</span>

  {activePlatforms.map((platform) => {
    const link = shareLinks[platform];
    const isCopy = platform === 'copy';
    const isEmail = platform === 'email';
    const icon = icons[platform] || '';

    return isCopy ? (
      <button
        class={`social-share-enhanced-btn social-share-enhanced-btn--${platform}`}
        aria-label={link.ariaLabel}
        data-social-share-enhanced-copy
        type="button"
      >
        <span class="social-share-enhanced-icon" set:html={icon} />
        {showLabels && <span class="social-share-enhanced-btn-label">{link.label}</span>}
      </button>
    ) : (
      <a
        href={link.href}
        target={isEmail ? '_self' : '_blank'}
        rel={isEmail ? undefined : 'noopener noreferrer'}
        class={`social-share-enhanced-btn social-share-enhanced-btn--${platform}`}
        aria-label={link.ariaLabel}
      >
        <span class="social-share-enhanced-icon" set:html={icon} />
        {showLabels && <span class="social-share-enhanced-btn-label">{link.label}</span>}
      </a>
    );
  })}
</div>

<!-- ===================================================================== -->
<!--  Floating Mobile Share Button                                         -->
<!-- ===================================================================== -->
{showFloatingButton && (
  <button
    class="social-share-enhanced-fab"
    aria-label="Share this page"
    data-social-share-enhanced-fab
    type="button"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="18" cy="5" r="3"/>
      <circle cx="6" cy="12" r="3"/>
      <circle cx="18" cy="19" r="3"/>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
    </svg>
  </button>
)}

<!-- ===================================================================== -->
<!--  Client-side behaviour                                                -->
<!-- ===================================================================== -->
<script define:vars={{ url }}>
  function initSocialShareEnhanced() {
    // --- Copy-to-clipboard buttons ---
    document.querySelectorAll('[data-social-share-enhanced-copy]').forEach((btn) => {
      // Remove old listeners by cloning
      const fresh = btn.cloneNode(true);
      btn.parentNode?.replaceChild(fresh, btn);

      fresh.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url || window.location.href);
          const original = fresh.getAttribute('aria-label');
          fresh.setAttribute('aria-label', 'Copied!');
          fresh.classList.add('social-share-enhanced-btn--copied');
          setTimeout(() => {
            fresh.setAttribute('aria-label', original || 'Copy link');
            fresh.classList.remove('social-share-enhanced-btn--copied');
          }, 2000);
        } catch {
          // Silent failure
        }
      });
    });

    // --- Floating action button ---
    document.querySelectorAll('[data-social-share-enhanced-fab]').forEach((fab) => {
      const fresh = fab.cloneNode(true);
      fab.parentNode?.replaceChild(fresh, fab);

      fresh.addEventListener('click', async () => {
        // Prefer Web Share API on supporting devices
        if (navigator.share) {
          try {
            await navigator.share({
              title: document.title,
              url: url || window.location.href,
            });
          } catch {
            // User cancelled
          }
        } else {
          // Scroll to the inline share bar as fallback
          const bar = document.querySelector('[data-social-share-enhanced]');
          if (bar) {
            bar.scrollIntoView({ behavior: 'smooth', block: 'center' });
            bar.classList.add('social-share-enhanced-highlight');
            setTimeout(
              () => bar.classList.remove('social-share-enhanced-highlight'),
              1500,
            );
          }
        }
      });
    });
  }

  initSocialShareEnhanced();
  document.addEventListener('astro:after-swap', initSocialShareEnhanced);
</script>
