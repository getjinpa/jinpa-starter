---
/**
 * ReadingProgress — Jinpa Plugin Component
 *
 * Renders a thin, animated progress bar fixed to the top of the viewport.
 * As the user scrolls through the page content, the bar fills from left
 * to right. Ideal for long-form blog posts and articles.
 *
 * All CSS classes are prefixed with "reading-progress-" to avoid conflicts
 * (per Jinpa plugin conflict resolution rules).
 */

interface Props {
  /** Bar color — any valid CSS color or variable. */
  color?: string;
  /** Bar thickness. */
  height?: string;
  /** CSS z-index. */
  zIndex?: string;
  /** Show a small floating percentage badge. */
  showPercentage?: boolean;
  /** CSS selector for the scrollable content container. Defaults to "article" or the full document. */
  contentSelector?: string;
}

const {
  color = 'var(--reading-progress-color, var(--color-primary, #2563eb))',
  height = 'var(--reading-progress-height, 3px)',
  zIndex = 'var(--reading-progress-z-index, 9999)',
  showPercentage = false,
  contentSelector = '',
} = Astro.props;
---

<div
  class="reading-progress-container"
  role="progressbar"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
  aria-label="Reading progress"
  style={`--rp-color: ${color}; --rp-height: ${height}; --rp-z: ${zIndex};`}
>
  <div class="reading-progress-bar"></div>
  {showPercentage && (
    <span class="reading-progress-badge" aria-hidden="true">0 %</span>
  )}
</div>

<script define:vars={{ contentSelector, showPercentage }}>
  function initReadingProgress() {
    const container = document.querySelector('.reading-progress-container');
    if (!container) return;

    const bar = container.querySelector('.reading-progress-bar');
    const badge = container.querySelector('.reading-progress-badge');

    /** Determine the element whose scroll extent we track. */
    function getContentBounds() {
      let el = null;
      if (contentSelector) {
        el = document.querySelector(contentSelector);
      }
      if (!el) {
        el = document.querySelector('article') || document.querySelector('.post-content');
      }
      if (el) {
        const rect = el.getBoundingClientRect();
        return {
          top: rect.top + window.scrollY,
          height: rect.height,
        };
      }
      // Fallback: full document
      return {
        top: 0,
        height: document.documentElement.scrollHeight - window.innerHeight,
      };
    }

    let ticking = false;

    function update() {
      const bounds = getContentBounds();
      const scrollY = window.scrollY;

      // How far through the content region are we?
      let progress = 0;
      if (bounds.height > 0) {
        const contentScroll = scrollY - bounds.top + window.innerHeight;
        progress = Math.min(
          100,
          Math.max(0, (contentScroll / bounds.height) * 100),
        );
      }

      if (bar) {
        bar.style.width = `${progress}%`;
      }
      container.setAttribute('aria-valuenow', String(Math.round(progress)));

      if (badge && showPercentage) {
        badge.textContent = `${Math.round(progress)} %`;
        badge.style.opacity = progress > 0 && progress < 100 ? '1' : '0';
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });

    // Initial calculation
    update();
  }

  // Run on page load and after Astro view-transition swaps
  initReadingProgress();
  document.addEventListener('astro:after-swap', initReadingProgress);
</script>
