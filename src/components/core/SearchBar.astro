---
// Pagefind search integration
// Pagefind v1 generates its index at build time in /_pagefind/
import { withBase } from '../../utils/paths';
const pagefindCss = withBase('/_pagefind/pagefind-ui.css');
const pagefindJs = withBase('/_pagefind/pagefind-ui.js');
---

<div class="search-container" id="search">
  <div id="pagefind-search" data-pagefind-js={pagefindJs}></div>
</div>

<link href={pagefindCss} rel="stylesheet" />

<script>
  async function initPagefind() {
    const el = document.getElementById('pagefind-search');
    if (!el) return;

    const pagefindJs = el.dataset.pagefindJs;
    if (!pagefindJs) return;

    try {
      // pagefind-ui.js is an IIFE — no ES module exports, but it sets
      // window.PagefindUI as a side-effect when the script runs.
      // We import() to execute it, then read the global it populated.
      await import(/* @vite-ignore */ pagefindJs);
      // @ts-ignore
      const PagefindUI = window.PagefindUI;
      if (typeof PagefindUI !== 'function') throw new Error('PagefindUI not available');
      new PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        showImages: false,
      });
    } catch {
      // Pagefind not available (e.g., during local dev without a build)
      el.innerHTML = '<p style="color: var(--color-text-muted); font-size: var(--font-size-sm);">Search is available after building the site.</p>';
    }
  }

  initPagefind();
  document.addEventListener('astro:after-swap', initPagefind);
</script>
