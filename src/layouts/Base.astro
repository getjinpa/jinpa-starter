---
import { ClientRouter } from 'astro:transitions';
import Head from '../components/core/Head.astro';
import Header from '../components/core/Header.astro';
import Footer from '../components/core/Footer.astro';
import siteConfig from '../../site.config.json';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const {
  title,
  description = siteConfig.site.description,
  image,
  article = false,
} = Astro.props;

const pageTitle = title ? `${title} | ${siteConfig.site.title}` : siteConfig.site.title;
---

<!doctype html>
<html lang={siteConfig.site.language} data-theme="light">
  <head>
    <Head title={pageTitle} description={description} image={image} article={article} />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <slot name="header">
      <Header />
    </slot>

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer">
      <Footer />
    </slot>

    <script is:inline>
      // Theme initialization - runs before paint to prevent flash
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </body>
</html>
