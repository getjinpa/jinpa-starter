{
  "$schema": "https://jinpa.dev/schemas/theme.config.v1.json",
  "version": 1,
  "name": "Starter Blog",
  "slug": "starter-blog",
  "author": "Vajradog",
  "authorUrl": "https://himalayanelders.org",
  "description": "A clean, minimal blog theme.",
  "license": "free",
  "preview": "https://example.github.io/starter-blog/",
  "thumbnail": "/site/theme-thumbnail.jpg",

  "settings": {
    "colors": {
      "primary": "#2563eb",
      "secondary": "#7c3aed",
      "accent": "#f59e0b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#1e293b",
      "textMuted": "#64748b"
    },
    "fonts": {
      "heading": "Inter, system-ui, sans-serif",
      "body": "Inter, system-ui, sans-serif",
      "mono": "ui-monospace, monospace"
    },
    "spacing": {
      "unit": "1rem",
      "scale": [0.25, 0.5, 0.75, 1, 1.5, 2, 3, 4, 6, 8]
    },
    "borderRadius": "0.375rem",
    "maxWidth": "72rem"
  },

  "features": {
    "darkMode": true,
    "search": true,
    "rss": true,
    "sitemap": true,
    "analytics": false,
    "comments": false,
    "multilingual": false,
    "viewTransitions": true,
    "csp": false
  },

  "contentTypes": [],
  "customSettings": {}
}
