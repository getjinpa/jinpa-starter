{
  "$schema": "https://getjinpa.com/schemas/theme.config.v1.json",
  "version": 1,
  "name": "Starter Blog",
  "slug": "starter-blog",
  "author": "Jinpa",
  "authorUrl": "https://getjinpa.com",
  "description": "A clean, minimal blog theme with dark mode, search, and RSS.",
  "license": "free",
  "preview": "https://getjinpa.github.io/jinpa-starter/",
  "thumbnail": "/site/theme-thumbnail.jpg",

  "settings": {
    "colors": {
      "primary": "#b5451b",
      "secondary": "#6b4c1e",
      "accent": "#d4951a",
      "background": "#ffffff",
      "surface": "#fdf9f5",
      "text": "#271400",
      "textMuted": "#7a5c45"
    },
    "fonts": {
      "heading": "Inter, system-ui, sans-serif",
      "body": "Inter, system-ui, sans-serif",
      "mono": "ui-monospace, monospace"
    },
    "spacing": {
      "unit": "1rem",
      "scale": [0.25, 0.5, 0.75, 1, 1.5, 2, 3, 4, 6, 8]
    },
    "borderRadius": "0.375rem",
    "maxWidth": "72rem"
  },

  "features": {
    "darkMode": true,
    "search": true,
    "rss": true,
    "sitemap": true,
    "analytics": false,
    "comments": false,
    "multilingual": false,
    "viewTransitions": true,
    "csp": false
  },

  "contentTypes": [],
  "customSettings": {}
}
